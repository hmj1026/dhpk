{
  "_comment": "Workflow routing SSOT for dhpk. Used by userpromptsubmit-skill-hint.sh (advisory hint) and by future /dhpk:do Smart Router (Phase 2). Patterns are ERE (extended regex). First match wins. Add specific patterns before general ones.",
  "schema": "dhpk.route-table.v1",
  "rules": [
    { "pattern": "(^|[^a-z])(bug|crash|broken|stack[ -]?trace|exception|failure|fail(s|ed|ing)?|error[ -]?out|regress(ion|ed)?)([^a-z]|$)", "skill": "dhpk:adaptive-dev-workflow",       "label": "adaptive dev workflow (bug)" },
    { "pattern": "(new|add(ing)?|implement(ing)?|build(ing)?|create) +.{0,40}(feature|endpoint|page|action|module|api)",                                                       "skill": "dhpk:adaptive-dev-workflow",    "label": "adaptive dev workflow (feature)" },
    { "pattern": "(code +review|review +(this|the|my)? *(diff|change|patch|pr)|quality +check|lint +everything)",                                                                "skill": "dhpk:code-review",    "label": "manual code review" },
    { "pattern": "(security +(scan|audit|review)|owasp|injection|xss|csrf|auth +bypass)",                                                                                       "skill": "dhpk:security-review","label": "security review" },
    { "pattern": "(explore|trace|how +does|walk +through|map +the|understand +the).{0,40}(code|flow|module|architecture)",                                                      "skill": "dhpk:code-explore",   "label": "code exploration" },
    { "pattern": "(audit|inventory|health|stocktake).{0,40}(project|repo|codebase|harness|skill|agent)",                                                                        "skill": "dhpk:project-audit",  "label": "project audit" },
    { "pattern": "(deploy(ment|ing)?|publish|release|ship).{0,40}(list|manifest|files|plan)",                                                                                   "skill": "dhpk:deploy-list",    "label": "deploy list" },
    { "pattern": "(refactor(ing)?|simplify|cleanup|dedup(licate)?|tidy +up)",                                                                                                   "skill": "dhpk:simplify",       "label": "refactor / simplify" },
    { "pattern": "(tech(nical)? +spec|requirements +doc|design +doc|architecture +doc)",                                                                                        "skill": "dhpk:tech-spec",      "label": "tech spec authoring" },
    { "pattern": "(smart +)?commit|stage +(and +)?commit",                                                                                                                       "skill": "dhpk:smart-commit",   "label": "smart commit" },
    { "pattern": "(create|open|draft).{0,20}(pr|pull +request|merge +request)",                                                                                                  "skill": "dhpk:create-pr",      "label": "create PR" },
    { "pattern": "(feasibility|first +principles|estimate +effort|estimate +scope)",                                                                                              "skill": "dhpk:feasibility-study","label": "feasibility study" },
    { "pattern": "(risk +(assess|analysis|audit)|blast +radius|impact +analysis)",                                                                                                "skill": "dhpk:risk-assess",    "label": "risk assessment" },
    { "pattern": "(precommit|pre[- ]commit|pre +push)",                                                                                                                          "skill": "dhpk:precommit",      "label": "pre-commit checks" },
    { "pattern": "(verify|verification|run +all +tests|full +test +run)",                                                                                                        "skill": "dhpk:verify",         "label": "verification loop" },
    { "pattern": "修.{0,8}(bug|錯誤|問題|缺陷|異常)",                                                                                                                              "skill": "dhpk:adaptive-dev-workflow",        "label": "adaptive dev workflow (bug)" },
    { "pattern": "(新增|加上?|寫個?|新做|實作).{0,12}(功能|特性|feature|頁面|端點|api)",                                                                                              "skill": "dhpk:adaptive-dev-workflow",    "label": "adaptive dev workflow (feature)" },
    { "pattern": "(程式碼|代碼)?\\s*(審查|review)",                                                                                                                                  "skill": "dhpk:code-review",    "label": "manual code review" },
    { "pattern": "(重構|簡化|清理|去重)",                                                                                                                                            "skill": "dhpk:simplify",       "label": "refactor / simplify" },
    { "pattern": "(探索|追蹤|理解|釐清).{0,12}(程式|代碼|流程|架構|呼叫|實作)",                                                                                                       "skill": "dhpk:code-explore",   "label": "code exploration" },
    { "pattern": "(健診|健康檢查|體檢|盤點).{0,12}(專案|代碼|harness|skill|agent)",                                                                                                  "skill": "dhpk:project-audit",  "label": "project audit" }
  ]
}
