{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Copy this file to <project>/.claude/settings.local.json (gitignored, must be a real file — not a symlink). dhpk's project-config loader reads settings.local.json first and falls back to settings.json; put per-developer pluginConfigs overrides here and team-shared ones in settings.json. Add personal permissions (SSH / curl / local tool paths) under permissions.allow as needed.",
  "permissions": {
    "allow": []
  },
  "pluginConfigs": {
    "dhpk@dhpk": {
      "options": {
        "modules": ["<stack-module>", "<test-module>"],
        "hook_profile": "standard"
      }
    }
  }
}
